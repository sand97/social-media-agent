# Database
DATABASE_URL="postgresql://user:password@localhost:5432/whatsapp_agent?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
QR_JWT_SECRET="your-qr-jwt-secret-change-in-production"
AGENT_INTERNAL_JWT_SECRET="your-agent-internal-jwt-secret-change-in-production"

# Encryption
ENCRYPTION_KEY="your-32-character-encryption-key"
GOOGLE_OAUTH_CLIENT_SECRET_PATH="./google_client_secret.json"
GOOGLE_CONTACTS_REDIRECT_URI="https://api-chat.bedones.com/google/callback"
GOOGLE_CONTACTS_POST_AUTH_REDIRECT_URL="https://chat.bedones.com"

# Server
PORT=3000
NODE_ENV=development
BACKEND_URL="http://localhost:3000"
BACKEND_INTERNAL_URL="https://127.0.0.1:9443"
FRONTEND_URL="http://localhost:5173"
STACK_POOL_PROVISION_ON_BOOT="true"
STACK_POOL_BOOTSTRAP_VPS_COUNT="0"
STACK_POOL_MIN_FREE_STACKS="4"
STACK_POOL_DEFAULT_STACKS_PER_VPS="2"
STACK_POOL_DEFAULT_SERVER_TYPE="cpx22"
STACK_POOL_DEFAULT_LOCATION="nbg1"
STACK_POOL_HETZNER_POLL_INTERVAL_MS="5000"
STACK_POOL_RESERVATION_TTL_MINUTES="15"
STACK_POOL_SERVER_NAME_PREFIX="bedones-wa"
HERZNET_API_KEY=""
HERZNET_SSH_KEY_NAMES=""
STACK_POOL_HETZNER_IMAGE="docker-ce"
GITHUB_ACTIONS_REPOSITORY=""
GITHUB_ACTIONS_TOKEN=""
GITHUB_ACTIONS_REF="main"
GITHUB_PROVISION_WORKFLOW_FILE="install-bedones-whatsapp-agent.yml"
GITHUB_RELEASE_WORKFLOW_FILE="release-bedones-whatsapp-agent.yml"
INFRA_ADMIN_TOKEN=""
STACK_INFRA_CALLBACK_SECRET=""
# Cloudflare
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""
CLOUDFLARE_ACCOUNT_ID=""

# WhatsApp Connector
WHATSAPP_CONNECTOR_BASE_URL="http://localhost:3001"
WPPCONNECT_SECRET_KEY="THISISMYSECURETOKEN"
CONNECTOR_SECRET="your-connector-signature-secret"

# Minio
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_BUCKET="whatsapp-agent"


# Stripe
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Notch Pay
NOTCH_PUBLIC_KEY=""
NOTCH_PRIVATE_KEY=""
NOTCH_HASH_KEY=""

# API Documentation
API_TITLE="WhatsApp Agent API"
API_DESCRIPTION="API for WhatsApp Business automation platform"
API_VERSION="1.0.0"

# xAI Grok API - Primary model
XAI_API_KEY=xai----
XAI_MODEL=grok-3

# Gemini API (Google) - Fallback model
GEMINI_API_KEY=AI---
GEMINI_MODEL=gemini-2.5-pro
# AI model preference
PRIMARY_MODEL=gemini
FALLBACK_MODEL=grok

CORS_ORIGINS=http://localhost:5173
