{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json",
    "assets": [
      {
        "include": "i18n/**/*",
        "watchAssets": true,
        "outDir": "dist/apps/backend/src"
      },
      {
        "include": "generated/**/*",
        "watchAssets": true,
        "outDir": "dist/apps/backend/src"
      }
    ]
  }
}
