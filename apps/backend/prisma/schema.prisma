// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  MANAGER
  CUSTOMER
  PARTNER
}

enum UserStatus {
  PENDING_PAIRING // En attente du pairing WhatsApp
  PAIRING // Pairing en cours (a reçu le code)
  PAIRED // WhatsApp connecté mais onboarding non terminé
  ONBOARDING // En cours d'onboarding
  ACTIVE // Compte actif et opérationnel
  SUSPENDED // Compte suspendu
  DELETED // Compte supprimé
}

enum WhatsAppAgentStatus {
  PROVISIONING // En cours de provisioning
  RUNNING // Agent en cours d'exécution
  STOPPED // Agent arrêté
  ERROR // Erreur
  DELETED // Agent supprimé
}

enum ConnectionStatus {
  CONNECTED // WhatsApp connecté
  DISCONNECTED // WhatsApp déconnecté
  QR_REQUIRED // QR code requis
  PAIRING_REQUIRED // Code de pairing requis
}

enum OrderStatus {
  NEGOTIATION // En cours de négociation
  CONFIRMED // Commande confirmée
  DELIVERED // Commande livrée
  CANCELLED // Commande annulée
}

enum SubscriptionTier {
  STARTER
  PRO
  ENTERPRISE
}

enum CreditType {
  PURCHASE // Achat de crédits
  USAGE // Utilisation (décompte)
  REFUND // Remboursement
  SUBSCRIPTION // Crédits de l'abonnement
}

enum PaymentMethodType {
  CASH
  MOBILE_MONEY
}

enum BillingProvider {
  STRIPE
  NOTCH_PAY
}

enum BillingPaymentMethod {
  CARD
  MOBILE_MONEY
}

enum BillingPaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
  EXPIRED
}

enum SyncStatus {
  PENDING // En attente de démarrage
  IN_PROGRESS // Synchronisation en cours
  COMPLETED // Synchronisation terminée
  FAILED // Échec de la synchronisation
}

enum SyncImageStatus {
  PENDING // En attente de synchronisation des images
  SYNCING // Synchronisation des images en cours
  DONE // Synchronisation des images terminée
  FAILED // Échec de la synchronisation des images
}

enum GoogleContactSyncStatus {
  CREATED
  LINKED
}

enum StatusScheduleContentType {
  TEXT
  IMAGE
  VIDEO
}

enum StatusScheduleState {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

// ============================================
// MODELS
// ============================================

model User {
  id          String     @id @unique @default(cuid())
  phoneNumber String     @unique
  email       String?    @unique
  role        UserRole   @default(MANAGER)
  status      UserStatus @default(PENDING_PAIRING)

  // Profil WhatsApp importé (JSON)
  whatsappProfile Json? // { pseudo, avatar, verifiedName, etc. }

  // Token de pairing temporaire
  pairingToken          String? // Token unique pour la session de pairing
  pairingTokenExpiresAt DateTime? // Expiration du token (2 min)

  // Crédits
  credits Int @default(0)

  // Dates
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  whatsappAgent     WhatsAppAgent?
  businessInfo      BusinessInfo?
  onboardingThread  OnboardingThread?
  collections       Collection[]
  products          Product[]
  deliveryLocations DeliveryLocation[]
  paymentMethods    PaymentMethod[]
  orders            Order[]
  creditHistory     Credit[]
  billingPayments   BillingPayment[]
  subscription      Subscription?
  groups            Group[]
  customerContacts  CustomerContact[]
  dailyStats        UserDailyStat[]
  statusSchedules   StatusSchedule[]

  @@index([phoneNumber])
  @@index([status])
}

model WhatsAppAgent {
  id     String  @id @unique @default(cuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Configuration serveur
  ipAddress         String
  port              Int // Port de l'agent WhatsApp
  connectorPort     Int // Port du connector WhatsApp
  encryptedPassword String // Mot de passe chiffré pour accéder à l'agent
  encryptedGoogleContactsToken String? @db.Text
  googleContactsConnectedAt    DateTime?

  // Statuts
  status           WhatsAppAgentStatus @default(PROVISIONING)
  connectionStatus ConnectionStatus    @default(PAIRING_REQUIRED)

  // Synchronisation des données WhatsApp
  syncStatus          SyncStatus @default(PENDING)
  syncProgress        Json? // { clientInfo: { status, progress, timestamp }, catalog: { status, progress, details } }
  lastCatalogSyncedAt DateTime? // Dernière synchronisation du catalogue
  syncImageStatus     SyncImageStatus @default(PENDING)
  lastImageSyncDate   DateTime?
  lastImageSyncError  String?
  customDescriptionPrompt    String? @db.Text
  promptGeneratedAt          DateTime?
  promptBasedOnProductsCount Int?

  // Métadonnées (JSON pour flexibilité)
  metadata Json? // { containerId, vpsProvider, region, etc. }

  // Configuration IA
  testPhoneNumbers  String[] @default([]) // Numéros de téléphone de test
  testLabels        String[] @default([]) // Labels de test (l'IA répond uniquement à ces labels)
  labelsToNotReply  String[] @default([]) // Labels à exclure (l'IA ne répond pas à ces labels)
  productionEnabled Boolean  @default(false) // Mode production activé

  // Dates
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastHealthCheckAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([syncStatus])
}

model OnboardingThread {
  id     String @id @unique @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Score de contexte (0-100)
  score Int @default(0)

  // Contexte actuel de l'entreprise (Markdown)
  context String? @db.Text

  // Besoins identifiés (JSON)
  needs Json? // { products: [], delivery: [], payments: [], etc. }

  // Statut du thread
  status String @default("in_progress") // "in_progress", "completed"

  // Relations
  messages ThreadMessage[]

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([score])
}

model ThreadMessage {
  id       String           @id @unique @default(cuid())
  threadId String
  thread   OnboardingThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  // Rôle du message
  role String // "user", "assistant", "system"

  // Contenu du message
  content String @db.Text

  // Métadonnées au moment du message (JSON)
  metadata Json? // { score, context, needs, question, propositions }

  // Date
  createdAt DateTime @default(now())

  @@index([threadId])
  @@index([role])
  @@index([createdAt])
}

model BusinessInfo {
  id      String @id @unique @default(cuid())
  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Informations WhatsApp Business
  is_business  Boolean @default(false)
  whatsapp_id  String? // ID WhatsApp serialized (ex: 237657888690@c.us)
  tag          String? // Tag WhatsApp Business
  profile_name String? // Nom du profil (pseudo)
  avatar_url   String? // URL de l'avatar dans MinIO

  // Informations de base
  name        String?
  description String?
  address     String?
  city        String?
  country     String?
  website     String? // URL du site web
  email       String? // Email du business

  // Catégories WhatsApp Business (JSON)
  categories Json? // [{ id: "164243073639257", localized_display_name: "Hotel" }]

  // Horaires d'ouverture (JSON)
  business_hours Json? // { config: { mon: { mode: "open_24h" }, ... }, timezone: "Europe/Paris" }

  // Options de profil (JSON)
  profile_options Json? // { commerceExperience: "catalog", cartEnabled: true }

  // Coordonnées géographiques
  latitude  Float?
  longitude Float?

  // Numéros de téléphone supplémentaires
  phone_numbers String[] @default([]) // Array de numéros

  // Dates
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([whatsapp_id])
}

model Collection {
  id                     String  @id @unique @default(cuid())
  user_id                String
  user                   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  whatsapp_collection_id String? // ID de la collection dans WhatsApp

  // Informations de base
  name        String
  description String?

  // Relations
  products Product[]

  // Dates
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([whatsapp_collection_id])
}

model Product {
  id                  String      @id @unique @default(cuid())
  user_id             String
  user                User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  whatsapp_product_id String? // ID du produit dans WhatsApp Business
  collection_id       String?
  collection          Collection? @relation(fields: [collection_id], references: [id], onDelete: SetNull)

  // Informations de base
  name        String
  description String?
  coverImageDescription String?
  needsTextIndexing Boolean @default(true)
  price       Float?
  currency    String?
  category    String?
  retailer_id String? // Retailer ID depuis WhatsApp

  // Stock et disponibilité
  availability  String? // "in stock", "out of stock"
  max_available Int? // Quantité max disponible
  is_hidden     Boolean @default(false)
  is_sanctioned Boolean @default(false)
  checkmark     Boolean @default(false)

  // URLs
  url String? // URL du produit

  // Statut de revue WhatsApp (JSON)
  capability_to_review_status Json?   @default("[]") // [{ key: "WHATSAPP", value: "APPROVED" }]
  whatsapp_product_can_appeal Boolean @default(false) // Produit peut faire appel

  // Hashes d'images WhatsApp
  image_hashes_for_whatsapp String[] @default([]) // Array de hashes d'images WhatsApp

  // Vidéos (JSON)
  videos Json? // Array de vidéos du produit

  // Relations
  images   ProductImage[]
  metadata ProductMetadata[]

  // Suggestions de l'IA (JSON)
  ai_suggestions Json? // { spellingCorrections: [], metadataSuggestions: [], descriptionImprovements: [] }

  // Dates
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([user_id, needsTextIndexing])
  @@index([collection_id])
  @@index([whatsapp_product_id])
}

model ProductImage {
  id         String  @id @unique @default(cuid())
  product_id String
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  // Informations de l'image
  url            String // URL dans MinIO
  original_url   String? // URL originale WhatsApp complète (avec query params)
  normalized_url String? // URL normalisée (partie stable sans query params) pour comparaison
  whatsapp_image_hash String? // Hash WhatsApp de l'image (plus stable que l'URL)
  image_type     String  @default("main") // "main" ou "additional"
  image_index    Int     @default(0) // Index de l'image
  needsImageIndexing Boolean @default(true)

  // Dates
  created_at DateTime @default(now())

  @@index([product_id])
  @@index([product_id, needsImageIndexing])
  @@index([product_id, whatsapp_image_hash])
  @@index([image_type])
  @@index([normalized_url])
}

model ProductMetadata {
  id         String  @id @unique @default(cuid())
  product_id String
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  // Métadonnée
  key   String // Ex: "taille", "couleur", "stockage"
  value String // Ex: "M", "Rouge", "256GB"

  // Visibilité
  is_visible      Boolean @default(true) // Afficher au client ou non
  suggested_by_ai Boolean @default(false) // Suggéré par l'IA

  // Dates
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([product_id])
}

model DeliveryLocation {
  id     String @id @unique @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  country String
  city    String
  name    String // Nom de la zone (ex: "Centre-ville", "Banlieue nord")
  price   Float

  isActive Boolean @default(true)

  // Relations
  orders Order[]

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model PaymentMethod {
  id     String            @id @unique @default(cuid())
  userId String
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   PaymentMethodType

  // Pour Mobile Money
  mobileMoneyNumber String?
  mobileMoneyName   String?
  requiresProof     Boolean @default(false) // Demander une capture du transfert

  isActive Boolean @default(true)

  // Relations
  orders Order[]

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Order {
  id     String @id @unique @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Référence à la conversation WhatsApp (live data, pas de FK)
  whatsappChatId String // ID du chat WhatsApp d'où provient la commande

  // Informations client
  customerName  String
  customerPhone String

  // Produits (JSON array)
  products Json // [{ productId, name, quantity, price }, ...]

  // Totaux
  totalAmount Float

  // Livraison et paiement
  deliveryLocationId String?
  deliveryLocation   DeliveryLocation? @relation(fields: [deliveryLocationId], references: [id], onDelete: SetNull)

  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  // Statut
  status OrderStatus @default(NEGOTIATION)

  // Promesse de commande (pour relance automatique)
  promiseDate DateTime?

  // Dates
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deliveredAt       DateTime?
  reviewRequestedAt DateTime? // Date de demande d'avis

  @@index([userId])
  @@index([whatsappChatId])
  @@index([status])
}

model Credit {
  id     String     @id @unique @default(cuid())
  userId String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId String? @unique
  payment   BillingPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  amount Int // Positif = ajout, négatif = décompte
  type   CreditType

  description String

  // Message lié (pour les décomptes)
  relatedMessageId String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

model BillingPayment {
  id     String @id @unique @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider      BillingProvider
  paymentMethod BillingPaymentMethod
  status        BillingPaymentStatus @default(PENDING)

  reference          String  @unique
  providerSessionId  String? @unique
  providerPaymentId  String?
  providerCheckoutUrl String? @db.Text

  amount        Float
  currency      String
  durationMonths Int
  creditsAmount Int

  subscriptionTier SubscriptionTier
  phoneNumber      String?
  description      String

  metadata Json?

  processedAt   DateTime?
  failedAt      DateTime?
  failureReason String?  @db.Text

  creditGrant Credit?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([reference])
  @@index([createdAt])
}

model Subscription {
  id     String           @id @unique @default(cuid())
  userId String           @unique
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier   SubscriptionTier

  creditsIncluded Int // Crédits inclus dans l'abonnement
  creditsUsed     Int @default(0) // Crédits utilisés ce mois

  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  autoRenew Boolean  @default(true)

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tier])
}

model Group {
  id              String @id @unique @default(cuid())
  userId          String
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappGroupId String // ID WhatsApp du groupe (ex: "12345@g.us")
  name            String // Nom du groupe
  usage           String // Utilisation du groupe (ex: "Support client", "Ventes", "Notifications")

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, whatsappGroupId]) // Un user ne peut pas avoir le même groupe deux fois
  @@index([userId])
  @@index([whatsappGroupId])
}

model CustomerContact {
  id     String @id @unique @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phoneNumber       String
  whatsappChatId    String
  whatsappContactId String
  displayName       String
  whatsappPushName  String?
  organizationName  String?
  googleResourceName String?
  googleSyncStatus   GoogleContactSyncStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, phoneNumber])
  @@index([userId])
  @@index([phoneNumber])
  @@index([googleResourceName])
}

model AgentOperation {
  id String @id @unique @default(cuid())

  // Context
  agentId String? // ID de l'agent WhatsApp
  chatId  String // ID du chat WhatsApp (user ou groupe)
  userId  String? // ID de l'utilisateur propriétaire de l'agent

  // Messages
  userMessage   String @db.Text // Message initial de l'utilisateur
  agentResponse String @db.Text // Réponse finale de l'agent
  systemPrompt  String @db.Text // System prompt utilisé

  // Metrics
  totalTokens      Int? // Total tokens utilisés
  promptTokens     Int? // Tokens du prompt
  completionTokens Int? // Tokens de la completion
  durationMs       Int // Durée en millisecondes
  modelName        String? // Nom du modèle utilisé (grok-beta, gemini, etc.)

  // Tools execution
  toolsUsed Json? // Array des tools utilisés: [{ name, args, result, durationMs }]

  // Status
  status String  @default("success") // "success", "error", "rate_limited"
  error  String? @db.Text // Message d'erreur si échec

  // Metadata
  metadata Json? // Métadonnées additionnelles

  // Dates
  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([chatId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model UserDailyStat {
  id     String @id @unique @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  day String @db.VarChar(10)

  messages              Int @default(0)
  messagesHandled       Int @default(0)
  imageMessages         Int @default(0)
  imageMessagesHandled  Int @default(0)
  audioMessages         Int @default(0)
  audioMessagesHandled  Int @default(0)
  textMessages          Int @default(0)
  textMessagesHandled   Int @default(0)
  conversations         Int @default(0)
  tokens                Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, day])
  @@index([userId])
  @@index([day])
}

model StatusSchedule {
  id     String @id @unique @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  scheduledFor DateTime
  scheduledDay String @db.VarChar(10)
  timezone     String

  contentType StatusScheduleContentType
  textContent String?                   @db.Text
  caption     String?                   @db.Text
  mediaUrl    String?                   @db.Text

  status   StatusScheduleState @default(PENDING)
  attempts Int                 @default(0)

  lastError String?   @db.Text
  sentAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([scheduledDay])
  @@index([scheduledFor])
  @@index([status])
  @@index([userId, scheduledDay])
  @@index([status, scheduledFor])
}
