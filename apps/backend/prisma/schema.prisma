// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  MANAGER
  CUSTOMER
  PARTNER
}

enum UserStatus {
  PENDING_PAIRING // En attente du pairing WhatsApp
  PAIRING // Pairing en cours (a reçu le code)
  PAIRED // WhatsApp connecté mais onboarding non terminé
  ONBOARDING // En cours d'onboarding
  ACTIVE // Compte actif et opérationnel
  SUSPENDED // Compte suspendu
  DELETED // Compte supprimé
}

enum WhatsAppAgentStatus {
  PROVISIONING // En cours de provisioning
  RUNNING // Agent en cours d'exécution
  STOPPED // Agent arrêté
  ERROR // Erreur
  DELETED // Agent supprimé
}

enum ConnectionStatus {
  CONNECTED // WhatsApp connecté
  DISCONNECTED // WhatsApp déconnecté
  QR_REQUIRED // QR code requis
  PAIRING_REQUIRED // Code de pairing requis
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  LOCATION
  CONTACT
  STICKER
}

enum OrderStatus {
  NEGOTIATION // En cours de négociation
  CONFIRMED // Commande confirmée
  DELIVERED // Commande livrée
  CANCELLED // Commande annulée
}

enum SubscriptionTier {
  STARTER
  PRO
  ENTERPRISE
}

enum CreditType {
  PURCHASE // Achat de crédits
  USAGE // Utilisation (décompte)
  REFUND // Remboursement
  SUBSCRIPTION // Crédits de l'abonnement
}

enum PaymentMethodType {
  CASH
  MOBILE_MONEY
}

enum GroupType {
  IMPROVEMENT // Groupe d'amélioration (échange avec IA)
  ORDERS // Groupe de commandes
  SUPPORT // Groupe de support/réclamations
  CUSTOM // Groupe personnalisé
}

enum SyncStatus {
  PENDING // En attente de démarrage
  IN_PROGRESS // Synchronisation en cours
  COMPLETED // Synchronisation terminée
  FAILED // Échec de la synchronisation
}

// ============================================
// MODELS
// ============================================

model User {
  id          String     @id @unique @default(cuid())
  phoneNumber String     @unique
  email       String?    @unique
  role        UserRole   @default(MANAGER)
  status      UserStatus @default(PENDING_PAIRING)

  // Profil WhatsApp importé (JSON)
  whatsappProfile Json? // { pseudo, avatar, verifiedName, etc. }

  // Token de pairing temporaire
  pairingToken          String? // Token unique pour la session de pairing
  pairingTokenExpiresAt DateTime? // Expiration du token (2 min)

  // Crédits
  credits Int @default(0)

  // Dates
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  whatsappAgent     WhatsAppAgent?
  businessInfo      BusinessInfo?
  onboardingThread  OnboardingThread?
  collections       Collection[]
  products          Product[]
  tags              Tag[]
  groups            Group[]
  conversations     Conversation[]
  deliveryLocations DeliveryLocation[]
  paymentMethods    PaymentMethod[]
  orders            Order[]
  creditHistory     Credit[]
  subscription      Subscription?
  messages          Message[]

  @@index([phoneNumber])
  @@index([status])
}

model WhatsAppAgent {
  id     String  @id @unique @default(cuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Configuration serveur
  ipAddress         String
  port              Int // Port de l'agent WhatsApp
  connectorPort     Int // Port du connector WhatsApp
  encryptedPassword String // Mot de passe chiffré pour accéder à l'agent

  // Statuts
  status           WhatsAppAgentStatus @default(PROVISIONING)
  connectionStatus ConnectionStatus    @default(PAIRING_REQUIRED)

  // Synchronisation des données WhatsApp
  syncStatus   SyncStatus @default(PENDING)
  syncProgress Json? // { clientInfo: { status, progress, timestamp }, catalog: { status, progress, details } }

  // Métadonnées (JSON pour flexibilité)
  metadata Json? // { containerId, vpsProvider, region, etc. }

  // Configuration IA
  testPhoneNumbers   String[] @default([]) // Numéros de téléphone de test
  testLabels         String[] @default([]) // Labels de test (l'IA répond uniquement à ces labels)
  labelsToNotReply   String[] @default([]) // Labels à exclure (l'IA ne répond pas à ces labels)
  productionEnabled  Boolean  @default(false) // Mode production activé

  // Dates
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastHealthCheckAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([syncStatus])
}

model OnboardingThread {
  id     String @id @unique @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Score de contexte (0-100)
  score Int @default(0)

  // Contexte actuel de l'entreprise (Markdown)
  context String? @db.Text

  // Besoins identifiés (JSON)
  needs Json? // { products: [], delivery: [], payments: [], etc. }

  // Statut du thread
  status String @default("in_progress") // "in_progress", "completed"

  // Relations
  messages ThreadMessage[]

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([score])
}

model ThreadMessage {
  id       String           @id @unique @default(cuid())
  threadId String
  thread   OnboardingThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  // Rôle du message
  role String // "user", "assistant", "system"

  // Contenu du message
  content String @db.Text

  // Métadonnées au moment du message (JSON)
  metadata Json? // { score, context, needs, question, propositions }

  // Date
  createdAt DateTime @default(now())

  @@index([threadId])
  @@index([role])
  @@index([createdAt])
}

model BusinessInfo {
  id      String @id @unique @default(cuid())
  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Informations WhatsApp Business
  is_business  Boolean @default(false)
  whatsapp_id  String? // ID WhatsApp serialized (ex: 237657888690@c.us)
  tag          String? // Tag WhatsApp Business
  profile_name String? // Nom du profil (pseudo)
  avatar_url   String? // URL de l'avatar dans MinIO

  // Informations de base
  name        String?
  description String?
  address     String?
  city        String?
  country     String?
  website     String? // URL du site web
  email       String? // Email du business

  // Catégories WhatsApp Business (JSON)
  categories Json? // [{ id: "164243073639257", localized_display_name: "Hotel" }]

  // Horaires d'ouverture (JSON)
  business_hours Json? // { config: { mon: { mode: "open_24h" }, ... }, timezone: "Europe/Paris" }

  // Options de profil (JSON)
  profile_options Json? // { commerceExperience: "catalog", cartEnabled: true }

  // Coordonnées géographiques
  latitude  Float?
  longitude Float?

  // Numéros de téléphone supplémentaires
  phone_numbers String[] @default([]) // Array de numéros

  // Dates
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([whatsapp_id])
}

model Collection {
  id                     String  @id @unique @default(cuid())
  user_id                String
  user                   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  whatsapp_collection_id String? // ID de la collection dans WhatsApp

  // Informations de base
  name        String
  description String?

  // Relations
  products Product[]

  // Dates
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([whatsapp_collection_id])
}

model Product {
  id                  String      @id @unique @default(cuid())
  user_id             String
  user                User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  whatsapp_product_id String? // ID du produit dans WhatsApp Business
  collection_id       String?
  collection          Collection? @relation(fields: [collection_id], references: [id], onDelete: SetNull)

  // Informations de base
  name        String
  description String?
  price       Float?
  currency    String?
  category    String?
  retailer_id String? // Retailer ID depuis WhatsApp

  // Stock et disponibilité
  availability  String? // "in stock", "out of stock"
  max_available Int? // Quantité max disponible
  is_hidden     Boolean @default(false)
  is_sanctioned Boolean @default(false)
  checkmark     Boolean @default(false)

  // URLs
  url String? // URL du produit

  // Statut de revue WhatsApp (JSON)
  capability_to_review_status Json?   @default("[]") // [{ key: "WHATSAPP", value: "APPROVED" }]
  whatsapp_product_can_appeal Boolean @default(false) // Produit peut faire appel

  // Hashes d'images WhatsApp
  image_hashes_for_whatsapp String[] @default([]) // Array de hashes d'images WhatsApp

  // Vidéos (JSON)
  videos Json? // Array de vidéos du produit

  // Relations
  images   ProductImage[]
  metadata ProductMetadata[]

  // Suggestions de l'IA (JSON)
  ai_suggestions Json? // { spellingCorrections: [], metadataSuggestions: [], descriptionImprovements: [] }

  // Dates
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([collection_id])
  @@index([whatsapp_product_id])
}

model ProductImage {
  id         String  @id @unique @default(cuid())
  product_id String
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  // Informations de l'image
  url            String // URL dans MinIO
  original_url   String? // URL originale WhatsApp complète (avec query params)
  normalized_url String? // URL normalisée (partie stable sans query params) pour comparaison
  image_type     String  @default("main") // "main" ou "additional"
  image_index    Int     @default(0) // Index de l'image

  // Dates
  created_at DateTime @default(now())

  @@index([product_id])
  @@index([image_type])
  @@index([normalized_url])
}

model ProductMetadata {
  id         String  @id @unique @default(cuid())
  product_id String
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  // Métadonnée
  key   String // Ex: "taille", "couleur", "stockage"
  value String // Ex: "M", "Rouge", "256GB"

  // Visibilité
  is_visible      Boolean @default(true) // Afficher au client ou non
  suggested_by_ai Boolean @default(false) // Suggéré par l'IA

  // Dates
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([product_id])
}

model Tag {
  id     String  @id @unique @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  color    String  @default("#3B82F6") // Couleur hex
  isSystem Boolean @default(false) // Tag système (non modifiable)

  // Relations
  conversations ConversationTag[]

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([isSystem])
}

model Group {
  id     String    @id @unique @default(cuid())
  userId String?
  user   User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  type   GroupType @default(CUSTOM)

  isSystem Boolean @default(false) // Groupe système (non modifiable)

  // Relations
  conversations Conversation[]

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([isSystem])
}

model Conversation {
  id     String @id @unique @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Informations WhatsApp
  whatsappChatId String // ID du chat WhatsApp
  contactName    String?
  contactNumber  String

  // Dernier message
  lastMessage   String?
  lastMessageAt DateTime?

  // Flags
  requiresManualResponse Boolean @default(false)

  // Relations
  groupId  String?
  group    Group?            @relation(fields: [groupId], references: [id], onDelete: SetNull)
  tags     ConversationTag[]
  messages Message[]
  orders   Order[]

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, whatsappChatId])
  @@index([userId])
  @@index([groupId])
}

// Table de liaison pour la relation many-to-many entre Conversation et Tag
model ConversationTag {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([conversationId, tagId])
  @@index([conversationId])
  @@index([tagId])
}

model Message {
  id             String       @id @unique @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Informations WhatsApp
  whatsappMessageId String? // ID du message WhatsApp
  from              String
  to                String
  body              String?
  mediaUrl          String?
  type              MessageType @default(TEXT)

  // Flags
  isFromCustomer  Boolean @default(true)
  isGeneratedByAI Boolean @default(false)
  tokensUsed      Int     @default(0) // Nombre de tokens utilisés pour cette réponse

  // Statuts WhatsApp
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?

  // Dates
  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([userId])
  @@index([whatsappMessageId])
}

model DeliveryLocation {
  id     String @id @unique @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  country String
  city    String
  name    String // Nom de la zone (ex: "Centre-ville", "Banlieue nord")
  price   Float

  isActive Boolean @default(true)

  // Relations
  orders Order[]

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model PaymentMethod {
  id     String            @id @unique @default(cuid())
  userId String
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   PaymentMethodType

  // Pour Mobile Money
  mobileMoneyNumber String?
  mobileMoneyName   String?
  requiresProof     Boolean @default(false) // Demander une capture du transfert

  isActive Boolean @default(true)

  // Relations
  orders Order[]

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Order {
  id             String       @id @unique @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Informations client
  customerName  String
  customerPhone String

  // Produits (JSON array)
  products Json // [{ productId, name, quantity, price }, ...]

  // Totaux
  totalAmount Float

  // Livraison et paiement
  deliveryLocationId String?
  deliveryLocation   DeliveryLocation? @relation(fields: [deliveryLocationId], references: [id], onDelete: SetNull)

  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  // Statut
  status OrderStatus @default(NEGOTIATION)

  // Promesse de commande (pour relance automatique)
  promiseDate DateTime?

  // Dates
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deliveredAt       DateTime?
  reviewRequestedAt DateTime? // Date de demande d'avis

  @@index([userId])
  @@index([conversationId])
  @@index([status])
}

model Credit {
  id     String     @id @unique @default(cuid())
  userId String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount Int // Positif = ajout, négatif = décompte
  type   CreditType

  description String

  // Message lié (pour les décomptes)
  relatedMessageId String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

model Subscription {
  id     String           @id @unique @default(cuid())
  userId String           @unique
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier   SubscriptionTier

  creditsIncluded Int // Crédits inclus dans l'abonnement
  creditsUsed     Int @default(0) // Crédits utilisés ce mois

  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  autoRenew Boolean  @default(true)

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tier])
}
