{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "agent\\.e2e-spec\\.ts$",
  "modulePathIgnorePatterns": ["<rootDir>/dist/"],
  "moduleNameMapper": {
    "^@app/(.*)$": "<rootDir>/src/$1",
    "^@apps/common$": "<rootDir>/../../packages/common/dist/src"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
