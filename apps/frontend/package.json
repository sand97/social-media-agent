{
  "name": "frontend",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 5173\"",
    "build": "vite build && mkdir -p .output/server && cp instrument.server.mjs .output/server",
    "build:cloudflare": "pnpm run build",
    "build:pages": "pnpm run build && bash ./scripts/prepare-cloudflare-pages-build.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix",
    "deploy": "pnpm run build:pages && wrangler --cwd .cloudflare-pages pages deploy . --project-name=chat-bedones"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@cloudflare/vite-plugin": "^1.26.0",
    "@sentry/tanstackstart-react": "^10.42.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "antd": "^5.29.3",
    "axios": "^1.12.2",
    "dayjs": "^1.11.19",
    "dotenv-cli": "^11.0.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.545.0",
    "openapi-fetch": "^0.14.0",
    "openapi-react-query": "^0.5.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.0",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "wrangler": "^4.70.0"
  }
}
