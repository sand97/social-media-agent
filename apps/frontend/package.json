{
  "name": "frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run sync:swagger\"",
    "dev:server": "vite",
    "sync:swagger": "node ./tools/swagger-sync.js",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.2",
    "@apps/common": "workspace:*",
    "@tanstack/react-query": "^5.90.2",
    "antd": "^5.27.4",
    "antd-phone-input": "^0.3.15",
    "axios": "^1.12.2",
    "isbot": "^5",
    "openapi-fetch": "^0.14.0",
    "openapi-react-query": "^0.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.2",
    "react-scripts": "^5.0.1",
    "socket.io-client": "^4.8.1",
    "typescript": "^4.9.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "chokidar": "^4.0.3",
    "concurrently": "^9.2.1",
    "openapi-typescript": "^7.9.1",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.3.3",
