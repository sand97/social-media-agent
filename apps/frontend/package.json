{
  "name": "frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run sync:swagger\"",
    "dev:server": "react-router dev",
    "sync:swagger": "node ./tools/swagger-sync.js",
    "start": "react-router-serve ./build/server/index.js",
    "type-check": "react-router typegen && tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.2",
    "@apps/common": "workspace:*",
    "@react-router/node": "^7.7.1",
    "@react-router/serve": "^7.7.1",
    "@tanstack/react-query": "^5.90.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "antd": "^5.27.4",
    "antd-phone-input": "^0.3.15",
    "axios": "^1.12.2",
    "isbot": "^5",
    "openapi-fetch": "^0.14.0",
    "openapi-react-query": "^0.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.7.1",
    "react-scripts": "^5.0.1",
    "typescript": "^4.9.5"
  },
  "devDependencies": {
    "@react-router/dev": "^7.7.1",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^22.10.7",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "chokidar": "^4.0.3",
    "openapi-typescript": "^7.9.1",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
