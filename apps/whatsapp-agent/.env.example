# Server
PORT=3002

NODE_ENV=development

# WhatsApp Connector
CONNECTOR_URL=http://localhost:3001
WHATSAPP_SESSION_NAME=whatsapp-agent-session
WPPCONNECT_SECRET_KEY=THISISMYSECURETOKEN

# Backend Server
BACKEND_URL=http://localhost:3000
CENTRAL_SERVER_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://app_user:app_password@localhost:5432/app_db?schema=public"

# Client Authentication
CLIENT_ID=local-dev-client
CLIENT_SECRET=dev-secret-key

# AI - Grok (xAI)
GROK_API_KEY=your-grok-api-key-here

# AI - Gemini (Google)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBEDDING_MODEL=text-embedding-004

# AI - Image embeddings (local CLIP via Xenova)
CLIP_IMAGE_MODEL=Xenova/clip-vit-base-patch16
# Must match active CLIP model output dimension
QDRANT_IMAGE_VECTOR_SIZE=512

# JWT for internal communication between whatsapp-agent and backend
# IMPORTANT: Ces deux valeurs doivent correspondre à celles du backend (.env du backend)
AGENT_INTERNAL_JWT_SECRET="your-agent-internal-jwt-secret-change-in-production"
# Pour générer AGENT_BACKEND_TOKEN:
# 1. Obtenir l'ID de votre agent WhatsApp depuis la BD:
#    node -e "const { PrismaClient } = require('./apps/backend/src/generated/client'); const prisma = new PrismaClient(); prisma.whatsAppAgent.findMany({ select: { id: true, userId: true } }).then(agents => { console.log(agents); prisma.\$disconnect(); });"
# 2. Mettre à jour l'ID dans generate-token.cjs (variable WHATSAPP_AGENT_ID)
# 3. Générer le token: NODE_PATH=./node_modules/.pnpm/jsonwebtoken@9.0.2/node_modules node generate-token.cjs
AGENT_BACKEND_TOKEN="generate-using-script-in-readme"

# Catalog Sync Optimization
# Par défaut (undefined ou false): toujours synchroniser le catalogue
# Si "true": activer l'optimisation (skip la synchro si le catalogue n'a pas changé basé sur hash)
# ENABLE_CATALOG_SYNC_OPTIMIZATION=true
