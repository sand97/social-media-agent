# WhatsApp Agent Production Environment Variables

# Port for WhatsApp Agent Service
PORT=3002

# URL of the WPPConnect Server (should point to the service on the same VPS)
CONNECTOR_URL=http://wppconnect-server:3001

# URL of the main Backend Server
# IMPORTANT: Update with your backend's public IP/domain or internal Docker network name if applicable
BACKEND_URL=http://your-backend-ip:3000
CENTRAL_SERVER_URL=http://your-backend-ip:3000 # Alias for BACKEND_URL

# AI - Grok (xAI)
# IMPORTANT: Replace with your actual API key in production
GROK_API_KEY=your-grok-api-key-here
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-beta

# AI - Gemini (Google)
# IMPORTANT: Replace with your actual API key in production
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp

# Agent configuration
AGENT_SYSTEM_PROMPT="You are a helpful WhatsApp assistant. You can read and send messages, get chat information, and help users with their WhatsApp conversations. Always be polite and helpful."

# Optional: Log level for WhatsApp Agent (e.g., debug, info, warn, error)
LOG_LEVEL=info
