{
  "name": "monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:all": "concurrently -n \"backend,frontend,agent\" -c \"bgBlue,bgMagenta,bgYellow\" \"pnpm dev:backend\" \"pnpm dev:frontend\" \"pnpm dev:whatsapp-agent\"",
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:whatsapp-agent": "pnpm --filter whatsapp-agent start:dev",
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build:whatsapp-agent": "pnpm --filter whatsapp-agent build",
    "build:whatsapp-connector": "pnpm --filter whatsapp-connector build",
    "start": "pnpm --filter backend start:prod",
    "start:whatsapp-agent": "pnpm --filter whatsapp-agent start:prod",
    "lint": "eslint . --max-warnings 600",
    "lint:fix": "eslint . --fix",
    "lint:backend": "eslint apps/backend --max-warnings 0",
    "lint:frontend": "pnpm --filter frontend lint",
    "lint:whatsapp-agent": "eslint apps/whatsapp-agent --max-warnings 0",
    "lint:whatsapp-connector": "eslint apps/whatsapp-connector --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "pnpm -r run type-check",
    "lint:all": "pnpm lint && pnpm format:check && pnpm type-check"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "prettier": "^3.6.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef"
}
